# ============================================
# AI PREMIUM SHOP — Environment Configuration
# ============================================

# Required: Site URL for sitemap, canonical URLs, and OG images
NEXT_PUBLIC_SITE_URL=https://aipremiumshop.com

# Required: WhatsApp Business number for order CTAs
NEXT_PUBLIC_WA_PRIMARY=8801865385348

# Optional: Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Facebook Pixel ID for conversion tracking
NEXT_PUBLIC_FB_PIXEL_ID=xxxxxxxxxxxxxxxx

# Notion CMS Integration (Optional — site works without it)
# 1. Create integration: https://www.notion.so/my-integrations
# 2. Share databases with integration
# 3. Copy database IDs from Notion URLs
# See NOTION_SETUP.md for full instructions
NOTION_API_KEY=
NOTION_DB_PRODUCTS=
NOTION_DB_VARIANTS=
NOTION_DB_CATEGORIES=
NOTION_DB_BLOG=
NOTION_DB_FAQ=

# Optional: Resend for email notifications
RESEND_API_KEY=

# Optional: Sentry for error tracking
SENTRY_AUTH_TOKEN=

# Optional: Database (only needed if using dynamic features)
DATABASE_URL=
DATABASE_URL_POOLED=
